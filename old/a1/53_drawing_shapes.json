        },
        {
            "order": 13,
            "person": 2,
            "text": "Can I copy your picture?",
            "translation": "می‌توانم نقاشی‌ات را کپی کنم؟"
        },
        {
            "order": 14,
            "person": 1,
            "text": "Sure, look at mine.",
            "translation": "حتماً، به مال من نگاه کن."
        },
