        {
            "order": 2,
            "person": 1,
            "text": "Draw a big circle in the middle.",
            "translation": "یک دایره بزرگ در وسط بکش."
        },
        {
            "order": 3,
            "person": 2,
            "text": "Like this? A round shape?",
            "translation": "این‌طوری؟ یک شکل گرد؟"
        },
        {
            "order": 4,
            "person": 1,
            "text": "Yes. Now draw a line on each side.",
            "translation": "بله. حالا در هر طرف یک خط بکش."
        },
        {
            "order": 5,
            "person": 2,
            "text": "On the left side and the right side?",
            "translation": "سمت چپ و سمت راست؟"
