    "Level": "A1",
    "estimatedDuration": 1,
    "sentences": [
        {
            "order": 0,
            "person": 1,
            "text": "Hello. Can I see your ticket and passport?",
            "translation": "سلام. می‌توانم بلیت و پاسپورتتان را ببینم؟"
        },
        {
            "order": 1,
            "person": 2,
            "text": "Here you are.",
            "translation": "بفرمایید."
        },
        {
            "order": 2,
            "person": 1,
            "text": "Thank you. How many bags are you checking?",
            "translation": "ممنون. چند چمدان تحویل می‌دهید؟"
        },
        {
            "order": 3,
            "person": 2,
            "text": "Just one suitcase.",
            "translation": "فقط یک چمدان."
        },
        {
            "order": 4,
            "person": 1,
            "text": "Please put your luggage here.",
            "translation": "لطفاً بار خود را اینجا بگذارید."
        },
        {
            "order": 5,
            "person": 2,
            "text": "Is the flight on time?",
            "translation": "پرواز سر وقت است؟"
        },
        {
            "order": 6,
            "person": 1,
            "text": "There is a short delay, about thirty minutes.",
            "translation": "کمی تأخیر است، حدود سی دقیقه."
        },
        {
            "order": 7,
            "person": 2,
            "text": "Okay. Which gate is it?",
            "translation": "باشه. کدام گیت است؟"
        },
        {
            "order": 8,
            "person": 1,
            "text": "Gate twelve, in terminal two.",
            "translation": "گیت دوازده، در ترمینال دو."
        },
        {
            "order": 9,
            "person": 2,
            "text": "Can I have a window seat?",
            "translation": "می‌توانم صندلی کنار پنجره داشته باشم؟"
        },
        {
            "order": 10,
            "person": 1,
            "text": "Yes. Here is your boarding pass.",
            "translation": "بله. این هم کارت پروازتان."
        },
        {
            "order": 11,
            "person": 1,
            "text": "Go through security first, then you can board the plane.",
            "translation": "اول از بازرسی امنیتی رد شوید، بعد می‌توانید سوار هواپیما شوید."
        },
        {
            "order": 12,
            "person": 2,
            "text": "When does it leave?",
            "translation": "کی حرکت می‌کند؟"
        },
        {
            "order": 13,
            "person": 1,
            "text": "Departure is at two o'clock. The plane will fly for three hours.",
            "translation": "پرواز ساعت دو است. هواپیما سه ساعت پرواز می‌کند."
        },
        {
            "order": 14,
            "person": 2,
            "text": "And when do we arrive?",
            "translation": "و کی می‌رسیم؟"
        },
        {
            "order": 15,
            "person": 1,
            "text": "The arrival is at five o'clock. After you land, go to customs.",
            "translation": "ورود ساعت پنج است. بعد از فرود، به گمرک بروید."
        },
        {
            "order": 16,
            "person": 2,
            "text": "Thank you. Have a good day.",
            "translation": "ممنون. روز خوبی داشته باشید."
        },
        {
            "order": 17,
            "person": 1,
            "text": "Have a safe trip!",
            "translation": "سفر خوبی داشته باشید!"
        }
    ]
}
