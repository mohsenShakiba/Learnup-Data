        {
            "order": 0,
            "person": 1,
            "text": "Hello, Green Street office.",
            "translation": "سلام، دفتر خیابان گرین."
        },
        {
            "order": 1,
            "person": 2,
            "text": "Hi, can you hear me?",
            "translation": "سلام، صدایم را می‌شنوی؟"
        },
        {
            "order": 2,
            "person": 1,
            "text": "Yes, but please speak louder.",
            "translation": "بله، اما لطفاً بلندتر صحبت کن."
        },
        {
            "order": 3,
            "person": 2,
            "text": "Is that better? I want to ask something.",
            "translation": "بهتر شد؟ می‌خواهم چیزی بپرسم."
        },
        {
            "order": 4,
            "person": 1,
            "text": "Go ahead. Let me take a note.",
            "translation": "بفرما. بگذار یادداشت کنم."
        },
        {
            "order": 5,
            "person": 2,
            "text": "Is your shop open today?",
            "translation": "مغازه‌تان امروز باز است؟"
        },
        {
            "order": 6,
            "person": 1,
            "text": "No, sorry, we're closed today.",
            "translation": "نه، متأسفم، امروز تعطیل هستیم."
        },
        {
            "order": 7,
            "person": 2,
            "text": "Oh, that's too bad.",
            "translation": "اوه، چه بد."
        },
        {
            "order": 8,
            "person": 1,
            "text": "We open again tomorrow morning.",
            "translation": "فردا صبح دوباره باز می‌کنیم."
        },
        {
            "order": 9,
            "person": 2,
            "text": "Okay. Thank you for your help.",
            "translation": "باشه. ممنون از کمکتان."
        },
        {
            "order": 10,
            "person": 1,
            "text": "You're welcome. Thanks for your call. Have a good day.",
            "translation": "خواهش می‌کنم. ممنون از تماس شما. روز خوبی داشته باشید."
        },
        {
            "order": 11,
            "person": 2,
            "text": "You too. Goodbye.",
            "translation": "شما هم همینطور. خداحافظ."
