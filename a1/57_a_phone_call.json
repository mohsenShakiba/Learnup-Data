        {
            "order": 5,
            "person": 2,
            "text": "Is your shop open today?",
            "translation": "مغازه‌تان امروز باز است؟"
        },
        {
            "order": 6,
            "person": 1,
            "text": "No, sorry, we are closed today.",
            "translation": "نه، متأسفم، امروز تعطیل هستیم."
        },
        {
            "order": 7,
            "person": 2,
            "text": "Oh, that is bad news.",
            "translation": "اوه، این خبر بدی است."
        },
        {
