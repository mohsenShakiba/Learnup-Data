        {
            "order": 0,
            "person": 1,
            "text": "Good evening. Welcome to the hotel.",
            "translation": "عصر بخیر. به هتل خوش آمدید."
        },
        {
            "order": 1,
            "person": 2,
            "text": "Thank you. I booked a room.",
            "translation": "ممنون. یک اتاق رزرو کرده‌ام."
        },
        {
            "order": 2,
            "person": 1,
            "text": "May I have your name?",
            "translation": "ممکن است نامتان را بفرمایید؟"
        },
        {
            "order": 3,
            "person": 2,
            "text": "It's David Clark.",
            "translation": "دیوید کلارک هستم."
        },
        {
            "order": 4,
            "person": 1,
            "text": "Yes, I see a room for two nights.",
            "translation": "بله، یک اتاق برای دو شب ثبت شده است."
        },
        {
            "order": 5,
            "person": 2,
            "text": "That's right.",
            "translation": "درست است."
        },
        {
            "order": 6,
            "person": 1,
            "text": "Please sign here.",
            "translation": "لطفاً اینجا را امضا کنید."
        },
        {
            "order": 7,
            "person": 2,
            "text": "Is breakfast free?",
            "translation": "صبحانه رایگان است؟"
        },
        {
            "order": 8,
            "person": 1,
            "text": "Yes, breakfast is from seven to ten.",
            "translation": "بله، صبحانه از هفت تا ده است."
        },
        {
            "order": 9,
            "person": 2,
            "text": "Great. Is there Wi-Fi?",
            "translation": "عالی. وای‌فای هست؟"
        },
        {
            "order": 10,
            "person": 1,
            "text": "Yes. The password is on this card.",
            "translation": "بله. رمز روی این کارت است."
        },
        {
            "order": 11,
            "person": 1,
            "text": "Here is your key. Room 204, second floor.",
            "translation": "این هم کلید شما. اتاق ۲۰۴، طبقه دوم."
        },
        {
            "order": 12,
            "person": 2,
            "text": "Thank you. Where is the elevator?",
            "translation": "ممنون. آسانسور کجاست؟"
        },
        {
            "order": 13,
            "person": 1,
            "text": "It's on your left. Enjoy your stay!",
            "translation": "سمت چپ شماست. از اقامتتان لذت ببرید!"
        },
        {
            "order": 14,
            "person": 2,
            "text": "Thank you very much.",
            "translation": "خیلی ممنون."
