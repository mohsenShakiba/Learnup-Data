{
    "title": "52 - A Lonely Friend",
    "description": "یک نفر دوستش را که در شهر جدید احساس تنهایی می‌کند دلداری می‌دهد.",
    "words": [
        "sad",
        "happen",
        "lonely",
        "alone",
        "feeling",
        "cry",
        "angry",
        "kind",
        "friend",
        "miss",
        "night"
    ],
    "Level": "A1",
    "estimatedDuration": 1,
    "sentences": [
        {
            "order": 0,
            "person": 1,
            "text": "You look sad today. What happened?",
            "translation": "امروز غمگین به نظر می‌رسی. چی شده؟"
        },
        {
            "order": 1,
            "person": 2,
            "text": "I feel lonely in this new city.",
            "translation": "در این شهر جدید احساس تنهایی می‌کنم."
        },
        {
            "order": 2,
            "person": 1,
            "text": "Are you often alone?",
            "translation": "اغلب تنها هستی؟"
        },
        {
            "order": 3,
            "person": 2,
            "text": "Yes, I am alone every night.",
            "translation": "بله، هر شب تنها هستم."
        },
        {
            "order": 4,
            "person": 1,
            "text": "That is a hard feeling.",
            "translation": "این حس سختی است."
        },
        {
            "order": 5,
            "person": 2,
            "text": "Sometimes I want to cry.",
            "translation": "بعضی وقت‌ها دلم می‌خواهد گریه کنم."
        },
        {
            "order": 6,
            "person": 1,
            "text": "Don't be sad. I am your friend.",
            "translation": "غمگین نباش. من دوستت هستم."
        },
        {
            "order": 7,
            "person": 2,
            "text": "Thank you. That is very kind.",
            "translation": "ممنون. خیلی مهربانی."
        },
        {
            "order": 8,
            "person": 1,
            "text": "Are you angry with anyone?",
            "translation": "از کسی عصبانی هستی؟"
        },
        {
            "order": 9,
            "person": 2,
            "text": "No, I just miss my family.",
            "translation": "نه، فقط دلم برای خانواده‌ام تنگ شده."
        },
        {
            "order": 10,
            "person": 1,
            "text": "Let's have dinner together tonight.",
            "translation": "بیا امشب با هم شام بخوریم."
        },
        {
            "order": 11,
            "person": 2,
            "text": "Yes! I feel much better now.",
            "translation": "بله! حالا خیلی بهتر شدم."
        }
    ]
}
