        {
            "order": 0,
            "person": 1,
            "text": "Our flat is very dirty today.",
            "translation": "آپارتمان ما امروز خیلی کثیف است."
        },
        {
            "order": 1,
            "person": 2,
            "text": "Yes, let's clean it together.",
            "translation": "بله، بیا با هم تمیزش کنیم."
        },
        {
            "order": 2,
            "person": 1,
            "text": "The garbage can is full.",
            "translation": "سطل آشغال پر است."
        },
        {
            "order": 3,
            "person": 2,
            "text": "I will carry it outside.",
            "translation": "من می‌برمش بیرون."
        },
        {
            "order": 4,
            "person": 1,
            "text": "Be careful, don't drop it.",
            "translation": "مواظب باش، نندازش."
        },
        {
            "order": 5,
            "person": 2,
            "text": "Okay. The walls need cleaning too.",
            "translation": "باشه. دیوارها هم باید تمیز شوند."
        },
        {
            "order": 6,
            "person": 1,
            "text": "I will wash this wall.",
            "translation": "من این دیوار را می‌شویم."
        },
        {
            "order": 7,
            "person": 2,
            "text": "Please clean the toilet too.",
            "translation": "لطفاً توالت را هم تمیز کن."
        },
        {
            "order": 8,
            "person": 1,
            "text": "Sure. Where is the soap?",
            "translation": "حتماً. صابون کجاست؟"
        },
        {
            "order": 9,
            "person": 2,
            "text": "It is under the sink.",
            "translation": "زیر سینک است."
        },
        {
            "order": 10,
            "person": 1,
            "text": "Good. Now the flat looks nice.",
            "translation": "خوبه. حالا آپارتمان قشنگ شده."
        },
        {
            "order": 11,
            "person": 2,
            "text": "Yes, much better. Thank you.",
            "translation": "بله، خیلی بهتر شد. ممنون."
