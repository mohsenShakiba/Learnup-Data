        {
            "order": 5,
            "person": 1,
            "text": "No, smoking is not allowed.",
            "translation": "نه، سیگار کشیدن مجاز نیست."
        },
        {
            "order": 6,
            "person": 2,
            "text": "Okay. What about phones?",
