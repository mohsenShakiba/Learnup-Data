        {
            "order": 0,
            "person": 1,
            "text": "Hi, I have a haircut at two.",
            "translation": "سلام، ساعت دو برای کوتاهی مو وقت دارم."
        },
        {
            "order": 1,
            "person": 2,
            "text": "Welcome. Please sit here.",
            "translation": "خوش آمدید. لطفاً اینجا بنشینید."
        },
        {
            "order": 2,
            "person": 2,
            "text": "What style would you like today?",
            "translation": "امروز چه مدلی می‌خواهید؟"
        },
        {
            "order": 3,
            "person": 1,
            "text": "Just a little shorter, please.",
            "translation": "فقط کمی کوتاه‌تر، لطفاً."
        },
        {
            "order": 4,
            "person": 2,
            "text": "Okay. Do you want a wash first?",
            "translation": "باشه. اول می‌خواهید بشورمش؟"
        },
        {
            "order": 5,
            "person": 1,
            "text": "Yes, please. And please cut a little at the back.",
            "translation": "بله لطفاً. و لطفاً پشت موها را کمی کوتاه کنید."
        },
        {
            "order": 6,
            "person": 2,
            "text": "What about the front?",
            "translation": "جلوی موها چطور؟"
        },
        {
            "order": 7,
            "person": 1,
            "text": "Keep the front long, please.",
            "translation": "جلو را بلند نگه دارید، لطفاً."
        },
        {
            "order": 8,
            "person": 2,
            "text": "Do you want any color today?",
            "translation": "امروز رنگ هم می‌خواهید؟"
        },
        {
            "order": 9,
            "person": 1,
            "text": "No, thank you. Just the cut.",
            "translation": "نه، ممنون. فقط کوتاهی."
        },
        {
            "order": 10,
            "person": 2,
            "text": "All done. Your hair is ready. Look in the mirror.",
            "translation": "تمام شد. موهایتان آماده است. به آینه نگاه کنید."
        },
        {
            "order": 11,
            "person": 1,
            "text": "It looks great. Thank you so much. Here is a tip.",
            "translation": "خیلی خوب شده. خیلی ممنون. این هم انعام."
        },
        {
            "order": 12,
            "person": 2,
            "text": "Thank you! Please come again.",
            "translation": "ممنون! لطفاً باز هم تشریف بیاورید."
