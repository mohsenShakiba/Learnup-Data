    "estimatedDuration": 1,
    "sentences": [
        {
            "order": 0,
            "person": 1,
            "text": "Excuse me, sorry to bother you. Can you help me?",
            "translation": "ببخشید، شرمنده که مزاحم می‌شوم. می‌توانید به من کمک کنید؟"
        },
        {
            "order": 1,
            "person": 2,
            "text": "Sure. What are you looking for?",
            "translation": "حتماً. دنبال چی می‌گردید؟"
        },
        {
            "order": 2,
            "person": 1,
            "text": "I'm looking for the bank.",
            "translation": "دنبال بانک می‌گردم."
        },
        {
            "order": 3,
            "person": 2,
            "text": "It's on Main Street. Just follow this road.",
            "translation": "توی خیابان اصلی است. فقط این جاده را دنبال کنید."
        },
        {
            "order": 4,
            "person": 1,
            "text": "Is it far?",
            "translation": "دور است؟"
        },
        {
            "order": 5,
            "person": 2,
            "text": "No, it's near. It's two blocks away, about five minutes.",
            "translation": "نه، نزدیک است. دو بلوک آن‌طرف‌تر است، حدود پنج دقیقه."
        },
        {
            "order": 6,
            "person": 1,
            "text": "How do I get there?",
            "translation": "چطور برسم آنجا؟"
        },
        {
            "order": 7,
            "person": 2,
            "text": "Walk straight, then cross the street at the corner.",
            "translation": "مستقیم بروید، بعد سر نبش از خیابان رد شوید."
        },
        {
            "order": 8,
            "person": 1,
            "text": "Left or right after that?",
            "translation": "بعد از آن، چپ یا راست؟"
        },
        {
            "order": 9,
            "person": 2,
            "text": "Turn left. The bank is behind the bus stop.",
            "translation": "به چپ بپیچید. بانک پشت ایستگاه اتوبوس است."
        },
        {
            "order": 10,
            "person": 1,
            "text": "Is it near the park?",
            "translation": "نزدیک پارک است؟"
        },
        {
            "order": 11,
            "person": 2,
            "text": "Yes, it's right across from the park.",
            "translation": "بله، درست روبه‌روی پارک است."
        },
        {
            "order": 12,
            "person": 1,
            "text": "Thank you so much. I was lost.",
            "translation": "خیلی ممنون. گم شده بودم."
        },
        {
            "order": 13,
            "person": 2,
            "text": "No problem. Take care!",
            "translation": "خواهش می‌کنم. مراقب خودتان باشید!"
        }
    ]
}
