    "sentences": [
        {
            "order": 0,
            "person": 1,
            "text": "Good morning! What can I get for you?",
            "translation": "صبح بخیر! چی براتون بیارم؟"
        },
        {
            "order": 1,
            "person": 2,
            "text": "Hi. Can I get a cup of coffee, please?",
            "translation": "سلام. میشه یه فنجان قهوه بگیرم، لطفاً؟"
        },
        {
            "order": 2,
            "person": 1,
            "text": "Sure. Small or large?",
            "translation": "حتماً. کوچک یا بزرگ؟"
        },
        {
            "order": 3,
            "person": 2,
            "text": "Large, please.",
            "translation": "بزرگ، لطفاً."
        },
        {
            "order": 4,
            "person": 1,
            "text": "Do you want milk and sugar?",
            "translation": "شیر و شکر می‌خواهید؟"
        },
        {
            "order": 5,
            "person": 2,
            "text": "Just milk, please. No sugar.",
            "translation": "فقط شیر، لطفاً. بدون شکر."
        },
        {
            "order": 6,
            "person": 1,
            "text": "Hot or cold?",
            "translation": "گرم یا سرد؟"
        },
        {
            "order": 7,
            "person": 2,
            "text": "Hot, please.",
            "translation": "گرم، لطفاً."
        },
        {
            "order": 8,
            "person": 1,
            "text": "Okay. Anything else?",
            "translation": "باشه. چیز دیگه‌ای می‌خواهید؟"
        },
        {
            "order": 9,
            "person": 2,
            "text": "Yes, and a tea, please. How much is it?",
            "translation": "بله، و یه چای هم، لطفاً. چقدر می‌شود؟"
        },
        {
            "order": 10,
            "person": 1,
            "text": "That's six dollars.",
            "translation": "شش دلار می‌شود."
        },
        {
            "order": 11,
            "person": 2,
            "text": "Can I pay by card?",
            "translation": "می‌توانم با کارت پرداخت کنم؟"
        },
        {
            "order": 12,
            "person": 1,
            "text": "Yes, of course.",
            "translation": "بله، البته."
        },
        {
            "order": 13,
            "person": 2,
            "text": "Thank you. I really like this cafe.",
            "translation": "ممنون. من این کافه را خیلی دوست دارم."
        },
        {
            "order": 14,
            "person": 1,
            "text": "Your drinks are ready. Have a great day!",
            "translation": "نوشیدنی‌هایتان آماده است. روز خوبی داشته باشید!"
        },
        {
            "order": 15,
            "person": 2,
            "text": "You too. Thank you!",
            "translation": "شما هم همینطور. ممنون!"
        }
    ]
