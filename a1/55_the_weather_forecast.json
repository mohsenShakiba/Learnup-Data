    "sentences": [
        {
            "order": 0,
            "person": 1,
            "text": "What's the weather like today?",
            "translation": "امروز هوا چطور است؟"
        },
        {
            "order": 1,
            "person": 2,
            "text": "It is cool and cloudy.",
            "translation": "خنک و ابری است."
        },
        {
            "order": 2,
            "person": 1,
            "text": "Will it be rainy?",
            "translation": "بارانی می‌شود؟"
        },
        {
            "order": 3,
            "person": 2,
            "text": "Yes, rainy in the afternoon, with thunder and lightning.",
            "translation": "بله، بعد از ظهر بارانی با رعد و برق."
        },
        {
            "order": 4,
            "person": 1,
            "text": "And tomorrow? What is the forecast?",
            "translation": "و فردا؟ پیش‌بینی هوا چیست؟"
        },
        {
            "order": 5,
            "person": 2,
            "text": "Tomorrow will be dry and sunny, with a light breeze.",
            "translation": "فردا خشک و آفتابی است، با یک نسیم ملایم."
        },
        {
            "order": 6,
            "person": 1,
            "text": "Good. I want to walk outside.",
            "translation": "خوبه. می‌خواهم بیرون قدم بزنم."
        },
        {
            "order": 7,
            "person": 2,
            "text": "It may be windy and foggy in the morning.",
            "translation": "ممکن است صبح باد و مه داشته باشیم."
        },
        {
            "order": 8,
            "person": 1,
            "text": "How many degrees will it be?",
            "translation": "چند درجه خواهد بود؟"
        },
        {
            "order": 9,
            "person": 2,
            "text": "About five degrees. It will freeze at night.",
            "translation": "حدود پنج درجه. شب یخ می‌زند."
        },
        {
            "order": 10,
            "person": 1,
            "text": "So cold! Should I wear boots and gloves?",
            "translation": "چه سرد! باید چکمه و دستکش بپوشم؟"
        },
        {
            "order": 11,
            "person": 2,
            "text": "Yes, and a warm coat.",
            "translation": "بله، و یک کت گرم."
        },
        {
            "order": 12,
            "person": 1,
            "text": "But next week it will be snowy.",
            "translation": "اما هفته بعد برفی می‌شود."
        },
        {
            "order": 13,
            "person": 2,
            "text": "Snow already? It's early.",
            "translation": "برف به این زودی؟ زود است."
        },
        {
            "order": 14,
            "person": 1,
            "text": "Maybe we will see a rainbow after the rain.",
            "translation": "شاید بعد از باران رنگین‌کمان ببینیم."
        },
        {
            "order": 15,
            "person": 2,
            "text": "Okay. I don't like the cold.",
            "translation": "باشه. سرما را دوست ندارم."
        },
        {
            "order": 16,
            "person": 1,
            "text": "Stay warm and dry!",
            "translation": "گرم و خشک بمان!"
        }
    ]
