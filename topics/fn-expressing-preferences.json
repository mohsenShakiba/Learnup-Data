{
  "grammar": {
    "name": "Expressing preferences",
    "levelId": 3,
    "order": 10,
    "estimatedTimeMinutes": 7,
    "description": "بیان ترجیح با prefer و would rather.",
    "parentGrammarId": 0,
    "lessons": [
      {
        "title": "بیان ترجیح",
        "htmlTag": 1,
        "content": "بیان ترجیح",
        "order": 1,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "بیان ترجیح",
        "htmlTag": 0,
        "content": "برای گفتن اینکه چه چیزی را بیشتر دوست داریم، از ساختارهایی مثل prefer و would rather استفاده می‌کنیم. هرکدام قاعده دستوری کمی متفاوتی دارند.",
        "order": 2,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "کاربرد 1: prefer",
        "htmlTag": 2,
        "content": "کاربرد 1: prefer",
        "order": 3,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "کاربرد 1: prefer",
        "htmlTag": 0,
        "content": "I prefer tea to coffee.",
        "order": 4,
        "language": "en",
        "voiceId": 0
      },
      {
        "title": "کاربرد 1: prefer",
        "htmlTag": 0,
        "content": "بعد از prefer برای مقایسه دو چیز از to استفاده می‌کنیم، نه than.",
        "order": 5,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "کاربرد 1: prefer",
        "htmlTag": 0,
        "content": "She prefers walking to driving.",
        "order": 6,
        "language": "en",
        "voiceId": 0
      },
      {
        "title": "کاربرد 1: prefer",
        "htmlTag": 0,
        "content": "بعد از prefer می‌توان فعل ing-دار هم آورد و باز هم مقایسه با to انجام می‌شود.",
        "order": 7,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "کاربرد 2: would rather",
        "htmlTag": 2,
        "content": "کاربرد 2: would rather",
        "order": 8,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "کاربرد 2: would rather",
        "htmlTag": 0,
        "content": "I'd rather stay home.",
        "order": 9,
        "language": "en",
        "voiceId": 0
      },
      {
        "title": "کاربرد 2: would rather",
        "htmlTag": 0,
        "content": "بعد از would rather فعل ساده و بدون to می‌آید. این یک تفاوت مهم با prefer است.",
        "order": 10,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "کاربرد 2: would rather",
        "htmlTag": 0,
        "content": "I'd rather walk than drive.",
        "order": 11,
        "language": "en",
        "voiceId": 0
      },
      {
        "title": "کاربرد 2: would rather",
        "htmlTag": 0,
        "content": "وقتی would rather دو گزینه را مقایسه می‌کند، از than استفاده می‌کنیم، نه to.",
        "order": 12,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "نکته مهم",
        "htmlTag": 2,
        "content": "نکته مهم",
        "order": 13,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "نکته مهم",
        "htmlTag": 0,
        "content": "نکته کلیدی در حرف اضافه است: prefer A to B اما would rather A than B. همچنین بعد از would rather فعل ساده می‌آید، نه to.",
        "order": 14,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "مثال‌های بیشتر",
        "htmlTag": 2,
        "content": "مثال‌های بیشتر",
        "order": 15,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "مثال‌های بیشتر",
        "htmlTag": 0,
        "content": "I prefer summer to winter.",
        "order": 16,
        "language": "en",
        "voiceId": 0
      },
      {
        "title": "مثال‌های بیشتر",
        "htmlTag": 0,
        "content": "prefer با to برای مقایسه دو فصل به کار رفته است.",
        "order": 17,
        "language": "fa",
        "voiceId": 0
      },
      {
        "title": "مثال‌های بیشتر",
        "htmlTag": 0,
        "content": "Would you rather have tea or coffee?",
        "order": 18,
        "language": "en",
        "voiceId": 0
      },
      {
        "title": "مثال‌های بیشتر",
        "htmlTag": 0,
        "content": "این یک سوال مودبانه برای پرسیدن ترجیح طرف مقابل است.",
        "order": 19,
        "language": "fa",
        "voiceId": 0
      }
    ]
  }
}