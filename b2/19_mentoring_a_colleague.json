{
  "title": "19 - Mentoring a Colleague",
  "description": "یک کارمند باتجربه به همکار جوان‌تری راهنمایی شغلی می‌دهد.",
  "words": [
    "mentor",
    "guidance",
    "potential",
    "confidence",
    "feedback",
    "develop",
    "growth",
    "encourage",
    "patient",
    "reflect",
    "ambition"
  ],
  "estimatedDuration": 1,
  "sentences": [
    {
      "order": 0,
      "person": 1,
      "text": "How are you settling into the role?",
      "translation": "چطور در این نقش جا می‌افتی؟"
    },
    {
      "order": 1,
      "person": 2,
      "text": "Honestly, I sometimes doubt myself.",
      "translation": "راستش، گاهی به خودم شک می‌کنم."
    },
    {
      "order": 2,
      "person": 1,
      "text": "That's natural early on.",
      "translation": "این در اوایل طبیعی است."
    },
    {
      "order": 3,
      "person": 2,
      "text": "How did you build your confidence?",
      "translation": "تو چطور اعتمادبه‌نفست را ساختی؟"
    },
    {
      "order": 4,
      "person": 1,
      "text": "By learning from my mistakes.",
      "translation": "با یاد گرفتن از اشتباهاتم."
    },
    {
      "order": 5,
      "person": 2,
      "text": "I worry about making them.",
      "translation": "نگران مرتکب شدنشان هستم."
    },
    {
      "order": 6,
      "person": 1,
      "text": "Mistakes are how you grow.",
      "translation": "اشتباهات همان راه رشد تو هستند."
    },
    {
      "order": 7,
      "person": 2,
      "text": "What do you think my strengths are?",
      "translation": "فکر می‌کنی نقاط قوت من چیست؟"
    },
    {
      "order": 8,
      "person": 1,
      "text": "You're analytical and very reliable.",
      "translation": "تحلیلی و خیلی قابل‌اعتماد هستی."
    },
    {
      "order": 9,
      "person": 2,
      "text": "That means a lot, thank you.",
      "translation": "این برایم ارزش زیادی دارد، ممنون."
    },
    {
      "order": 10,
      "person": 1,
      "text": "Just be patient with yourself.",
      "translation": "فقط با خودت صبور باش."
    },
    {
      "order": 11,
      "person": 2,
      "text": "I appreciate your guidance so much.",
      "translation": "خیلی از راهنمایی‌ات قدردانی می‌کنم."
    }
  ]
}
