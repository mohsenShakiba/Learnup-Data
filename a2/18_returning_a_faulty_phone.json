    },
    {
      "order": 3,
      "person": 2,
      "text": "When did you buy it?",
      "translation": "کی آن را خریدید؟"
    },
    {
      "order": 4,
      "person": 1,
      "text": "Two months ago. It's still under warranty.",
      "translation": "دو ماه پیش. هنوز گارانتی دارد."
    },
    {
      "order": 5,
      "person": 2,
      "text": "Let me check it.",
      "translation": "بگذارید بررسی‌اش کنم."
    },
    {
